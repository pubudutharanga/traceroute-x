---
import BaseLayout from "@/layouts/BaseLayout.astro"
import Header from "@/components/Header.astro"
import Footer from "@/components/Footer.astro"
import { getCollection } from "astro:content"

const allPosts = await getCollection("posts", ({ data }) => !data.draft)
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
)

const POSTS_PER_PAGE = 12
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE)
const posts = sortedPosts.slice(0, POSTS_PER_PAGE)
---

<BaseLayout title="Blog" description="Explore the latest in technical news, in-depth gadget reviews, software development, and AI breakthroughs.">
  <Header />

  <main class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8 sm:py-10">
    <div class="mb-8 sm:mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)]">Blog</h1>
      <p class="text-sm sm:text-base text-[var(--text-secondary)] mt-2">
        {sortedPosts.length} articles on tech, gadgets, software, and AI
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.slug}`}
          class="group block rounded-xl sm:rounded-2xl border border-[var(--border-primary)] overflow-hidden bg-[var(--bg-elevated)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 animate-fade-in"
          style={`animation-delay: ${i * 60}ms`}
        >
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={post.data.coverImage}
              alt={post.data.coverAlt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading={i < 3 ? "eager" : "lazy"}
              width="400"
              height="225"
            />
          </div>
          <div class="p-4 sm:p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2 py-0.5 rounded-full bg-[var(--bg-tertiary)] text-xs font-medium text-[var(--text-secondary)]">
                {post.data.category}
              </span>
              <span class="text-xs text-[var(--text-tertiary)]">
                {post.data.publishedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              </span>
            </div>
            <h2 class="text-sm sm:text-base font-semibold text-[var(--text-primary)] group-hover:text-[var(--text-link)] transition-colors line-clamp-2 mb-2">
              {post.data.title}
            </h2>
            <p class="text-xs sm:text-sm text-[var(--text-secondary)] line-clamp-2">
              {post.data.description}
            </p>
            <div class="flex items-center gap-2 mt-4 pt-3 border-t border-[var(--border-primary)]">
              <span class="text-xs text-[var(--text-tertiary)]">
                {post.data.readingTime} min read
              </span>
              <span class="text-xs text-[var(--text-tertiary)]">·</span>
              <span class="text-xs text-[var(--text-tertiary)] capitalize">
                {post.data.author.replace(/-/g, " ")}
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <nav class="flex items-center justify-center gap-1.5 sm:gap-2 mt-10 sm:mt-12" aria-label="Pagination">
        <span class="h-10 px-4 flex items-center justify-center rounded-md bg-[var(--color-brand-600)] text-white text-sm font-medium">
          1
        </span>
        {Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map(page => (
          <a
            href={`/blog/${page}`}
            class="h-10 px-4 flex items-center justify-center rounded-md text-sm font-medium text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] transition-colors"
          >
            {page}
          </a>
        ))}
      </nav>
    )}
  </main>

  <Footer />
</BaseLayout>
