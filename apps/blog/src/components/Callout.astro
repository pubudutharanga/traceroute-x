---
interface Props {
  type?: 'info' | 'tip' | 'warning' | 'error';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: 'bg-[var(--surface-info)] border-[var(--text-info)] text-[var(--text-info)]',
  tip: 'bg-[var(--surface-success)] border-[var(--text-success)] text-[var(--text-success)]',
  warning: 'bg-[var(--surface-warning)] border-[var(--text-warning)] text-[var(--text-warning)]',
  error: 'bg-[var(--surface-error)] border-[var(--text-error)] text-[var(--text-error)]',
};

const containerClass = styles[type] || styles.info;
---

<div class={`my-8 flex gap-4 p-5 rounded-lg border-l-4 shadow-sm animate-fade-in ${containerClass}`}>
  <div class="mt-0.5">
    {type === 'info' && (
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    )}
    {type === 'tip' && (
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.256 1.149-3.149L8.5 14.5z"/></svg>
    )}
    {type === 'warning' && (
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
    )}
    {type === 'error' && (
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
    )}
  </div>
  <div class="flex-1">
    {title && (
      <h4 class="font-bold text-lg mb-1 leading-tight tracking-tight">
        {title}
      </h4>
    )}
    <div class="prose-sm opacity-90 leading-relaxed">
      <slot />
    </div>
  </div>
</div>
