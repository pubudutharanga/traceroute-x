---
interface Props {
  label: string;
}

const { label } = Astro.props;
---
<div class="relative my-16 flex items-center justify-center">
  <div class="absolute inset-0 flex items-center" aria-hidden="true">
    <div class="w-full border-t border-slate-200 dark:border-slate-800"></div>
  </div>
  <div class="relative flex justify-center">
    <span class="bg-white dark:bg-slate-950 px-4 text-sm font-semibold tracking-widest text-slate-500 uppercase rounded-full shadow-sm border border-slate-200 dark:border-slate-800">
      {label}
    </span>
  </div>
</div>
