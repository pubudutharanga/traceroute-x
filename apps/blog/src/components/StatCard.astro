---
interface Props {
  label: string;
  value: string;
  trend?: string;
  description?: string;
}

const { label, value, trend, description } = Astro.props;

const isPositive = trend?.startsWith('+');
---

<div class="my-6 p-6 rounded-2xl border border-[var(--border-primary)] bg-[var(--bg-elevated)] shadow-md hover:shadow-lg transition-shadow duration-300 animate-fade-in group">
  <div class="flex flex-col gap-1">
    <dt class="text-[var(--text-tertiary)] text-xs font-bold uppercase tracking-widest">{label}</dt>
    <dd class="flex items-baseline gap-3">
      <span class="text-3xl md:text-4xl font-extrabold text-[var(--text-primary)] tracking-tight group-hover:text-[var(--color-brand-500)] transition-colors">
        {value}
      </span>
      {trend && (
        <span class={`text-sm font-bold px-2 py-0.5 rounded-full ${isPositive ? 'bg-[var(--surface-success)] text-[var(--text-success)]' : 'bg-[var(--surface-error)] text-[var(--text-error)]'}`}>
          {trend}
        </span>
      )}
    </dd>
    {description && (
      <p class="mt-2 text-sm text-[var(--text-secondary)] leading-snug">{description}</p>
    )}
  </div>
</div>
