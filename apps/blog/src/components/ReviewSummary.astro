---
export interface Props {
  review: {
    rating: number;
    pros: string[];
    cons: string[];
    verdict: string;
    price?: string;
  };
}

const { review } = Astro.props;

// Compute rating rendering
const fullStars = Math.floor(review.rating);
const hasHalfStar = review.rating % 1 !== 0;
const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
---

<div class="my-10 border border-[var(--border-primary)] rounded-2xl bg-[var(--bg-elevated)] overflow-hidden shadow-sm">
  {/* Header: Score & Verdict */}
  <div class="p-6 md:p-8 border-b border-[var(--border-primary)] bg-gradient-to-br from-[var(--bg-elevated)] to-[var(--bg-tertiary)]">
    <div class="flex flex-col md:flex-row gap-6 md:items-center">
      {/* Score Box */}
      <div class="flex-shrink-0 flex flex-col items-center justify-center p-4 rounded-xl bg-[var(--bg-primary)] border border-[var(--color-brand-200)] shadow-inner dark:border-[var(--color-brand-900)]">
        <span class="text-4xl font-black text-[var(--color-brand-600)] tabular-nums leading-none">
          {review.rating.toFixed(1)}
        </span>
        <span class="text-xs font-semibold text-[var(--text-tertiary)] mt-1 uppercase tracking-wider">
          Out of 5
        </span>
        <div class="flex items-center gap-0.5 mt-2 text-[var(--color-brand-500)]">
          {Array.from({ length: fullStars }).map(() => (
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
          {hasHalfStar && (
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><defs><clipPath id="half"><rect x="0" y="0" width="12" height="24" /></clipPath></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="var(--bg-tertiary)" /><path clip-path="url(#half)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
          )}
          {Array.from({ length: emptyStars }).map(() => (
            <svg class="w-4 h-4 fill-[var(--bg-tertiary)]" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
      </div>

      {/* Verdict */}
      <div class="flex-1">
        <h3 class="flex items-center gap-2 text-sm font-bold text-[var(--color-brand-600)] uppercase tracking-widest mb-2">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          The Verdict
        </h3>
        <p class="text-lg md:text-xl font-medium text-[var(--text-primary)] leading-tight mb-2">
          {review.verdict}
        </p>
        {review.price && (
          <p class="inline-block px-2.5 py-0.5 rounded-md bg-[var(--bg-primary)] border border-[var(--border-primary)] text-sm font-semibold text-[var(--text-secondary)]">
            Price: {review.price}
          </p>
        )}
      </div>
    </div>
  </div>

  {/* Pros & Cons */}
  <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-[var(--border-primary)]">
    <!-- Pros -->
    <div class="p-6 md:p-8 bg-[var(--color-success-50)] dark:bg-[var(--color-success-900)]/10">
      <h4 class="flex items-center gap-2 text-base font-bold text-green-700 dark:text-green-500 mb-4">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        The Good
      </h4>
      <ul class="space-y-2">
        {review.pros.map((pro) => (
          <li class="flex items-start gap-2.5 text-[var(--text-secondary)] text-sm">
            <span class="block w-1.5 h-1.5 rounded-full bg-green-500 mt-1.5 flex-shrink-0" />
            {pro}
          </li>
        ))}
      </ul>
    </div>

    <!-- Cons -->
    <div class="p-6 md:p-8 bg-[var(--color-error-50)] dark:bg-[var(--color-error-900)]/10">
      <h4 class="flex items-center gap-2 text-base font-bold text-red-700 dark:text-red-500 mb-4">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        The Bad
      </h4>
      <ul class="space-y-2">
        {review.cons.map((con) => (
          <li class="flex items-start gap-2.5 text-[var(--text-secondary)] text-sm">
            <span class="block w-1.5 h-1.5 rounded-full bg-red-500 mt-1.5 flex-shrink-0" />
            {con}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
