---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---
<figure class="my-10 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-xl bg-slate-50 dark:bg-slate-900 group transition-all hover:shadow-2xl">
  <div class="relative overflow-hidden aspect-video bg-slate-200 dark:bg-slate-800">
    <img 
      src={src} 
      alt={alt} 
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 ring-1 ring-inset ring-black/10 dark:ring-white/10 rounded-2xl pointer-events-none"></div>
  </div>
  {caption && (
    <figcaption class="px-4 py-3 text-sm text-center text-slate-500 dark:text-slate-400 font-medium">
      {caption}
    </figcaption>
  )}
</figure>
