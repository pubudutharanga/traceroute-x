{
  "name": "traceroutex",
  "version": "0.1.0",
  "private": true,
  "description": "TraceRoute X — A production-grade technology blog for US/UK readers",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@traceroutex/web",
    "dev:blog": "turbo run dev --filter=@traceroutex/blog",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@traceroutex/web",
    "build:blog": "turbo run build --filter=@traceroutex/blog",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,mdx,astro}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,mdx,astro}\"",
    "db:generate": "turbo run db:generate --filter=@traceroutex/db",
    "db:push": "turbo run db:push --filter=@traceroutex/db",
    "db:migrate": "turbo run db:migrate --filter=@traceroutex/db",
    "db:seed": "turbo run db:seed --filter=@traceroutex/db",
    "db:studio": "turbo run db:studio --filter=@traceroutex/db",
    "clean": "turbo run clean && rimraf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "rimraf": "^6.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
