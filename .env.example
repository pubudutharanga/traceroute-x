# ==============================================
# TraceRoute X — Environment Variables
# ==============================================
# Copy this file to .env and fill in the values

# ---- Database (Neon PostgreSQL) ----
DATABASE_URL="postgresql://user:password@host.neon.tech/traceroutex?sslmode=require"

# ---- Authentication (NextAuth.js v5) ----
NEXTAUTH_SECRET="generate-a-random-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- GitHub OAuth ----
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ---- Rate Limiting (Upstash Redis) ----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Public (exposed to client) ----
NEXT_PUBLIC_SITE_URL="http://localhost:4321"
NEXT_PUBLIC_SITE_NAME="TraceRoute X"
NEXT_PUBLIC_API_URL="http://localhost:3000"
